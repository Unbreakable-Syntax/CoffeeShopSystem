<Window x:Class="CoffeeAdminHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoffeeAdminHelper"
        mc:Ignorable="d"
        Title="CaffeiClick Admin Manager" Height="575" Width="1200" WindowStartupLocation="CenterScreen" Icon="/CoffeeCup.png" ResizeMode="CanMinimize">
    <Window.Resources>
        <!-- Reference the RoundedButton files here -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/RoundedButton.xaml"/>
                <ResourceDictionary Source="/RoundedTextbox.xaml"/>
                <ResourceDictionary Source="/RoundedPasswordBox.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="0,0,0,-6">
        <Canvas x:Name="AdminDashboard" Visibility="Collapsed" Margin="5,7,32,10">
            <Button FontSize="16" x:Name="SearchAccountButton" Height="28" Content="Search admin account" Background="Transparent" Style="{StaticResource RoundButtonStyle}" Width="176" Canvas.Left="33" Canvas.Top="439" HorizontalAlignment="Center" VerticalAlignment="Top" Click="SearchAccountButton_Click"/>
            <Button FontSize="16" x:Name="AddAccountButton" Height="28" Content="Add admin account" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource RoundButtonStyle}" Width="176" Canvas.Left="33" Canvas.Top="399" Click="AddAccountButton_Click"/>
            <Button FontSize="16" x:Name="LogoutAdmin" Height="28" Content="Logout superadmin" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top" Style="{StaticResource RoundButtonStyle}" Width="177" RenderTransformOrigin="0.497,0.972" Canvas.Left="32" Canvas.Top="478" Click="LogoutAdmin_Click"/>
            <Button FontSize="16" x:Name="ClearFieldsButton" Height="28" Content="Clear all input fields" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top" Style="{StaticResource RoundButtonStyle}" Width="188" RenderTransformOrigin="0.497,0.972" Canvas.Left="221" Canvas.Top="478" Click="ClearFieldsButton_Click"/>
            <Button FontSize="16" x:Name="RemoveAccountButton" Height="28" Content="Remove admin account" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource RoundButtonStyle}" Width="188" Canvas.Left="221" Canvas.Top="399" Click="RemoveAccountButton_Click"/>
            <Button FontSize="16" x:Name="UpdateAccountButton" Height="28" Content="Update admin account" ToolTip="The current admin username is used for this operation. Blank inputs will not be used when updating information." ToolTipService.InitialShowDelay="10" ToolTipService.ShowDuration="10000" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Top" Style="{StaticResource RoundButtonStyle}" Width="188" Canvas.Left="221" Canvas.Top="439" Click="UpdateAccountButton_Click"/>
            <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Admin username" VerticalAlignment="Center" Canvas.Left="67" Canvas.Top="42"/>
            <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="New admin username" VerticalAlignment="Center" Canvas.Left="33" Canvas.Top="80"/>
            <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="New admin password" VerticalAlignment="Center" Canvas.Left="34" Canvas.Top="118"/>
            <TextBox FontSize="16" x:Name="CurrentAdminUsername" HorizontalAlignment="Left" TextWrapping="NoWrap" VerticalAlignment="Center" Width="205" Style="{StaticResource RoundTextBoxStyle}" Canvas.Left="199" Canvas.Top="42"/>
            <TextBox FontSize="16" x:Name="NewAdminUsername" HorizontalAlignment="Left" TextWrapping="NoWrap" VerticalAlignment="Center" Width="205" Style="{StaticResource RoundTextBoxStyle}" Canvas.Left="199" Canvas.Top="80"/>
            <PasswordBox FontSize="16" x:Name="HiddenNewAdminPassword" HorizontalAlignment="Left" VerticalAlignment="Center" Width="205" Style="{StaticResource RoundPassBoxStyle}" Canvas.Left="199" Canvas.Top="117"/>
            <CheckBox FontSize="13" x:Name="ShowNewPassword" Content="Show password" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="239" Canvas.Top="155" Click="ShowNewPassword_Click"/>
            <CheckBox FontSize="13" x:Name="AllowPermissionUpdate" Content="Modify account permissions when updating" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="82" Canvas.Top="368"/>
            <TextBox FontSize="16" x:Name="ShownNewAdminPassword" Visibility="Collapsed" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Width="205" Style="{StaticResource RoundTextBoxStyle}" Canvas.Left="199" Canvas.Top="117"/>
            <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Regular administrator account permissions" VerticalAlignment="Center" Canvas.Left="68" Canvas.Top="187"/>
            <TextBlock FontSize="16" Canvas.Left="680" TextWrapping="Wrap" Text="Regular administrator accounts table" Canvas.Top="4" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock FontSize="16" Canvas.Left="93" TextWrapping="Wrap" Text="Regular admin account management" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Top="4"/>
            <DataGrid FontSize="16" x:Name="AdminTable" CanUserSortColumns="True" Canvas.Left="448" Canvas.Top="40" HorizontalAlignment="Left" VerticalAlignment="Center" Height="465" IsReadOnly="True" AutoGenerateColumns="False" Width="692" SelectionChanged="AdminTable_SelectionChanged" Visibility="Visible">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Admin Username" Binding="{Binding [Admin Username]}" SortMemberPath="Admin Username"/>
                    <DataGridTextColumn Header="Can Add Products" Binding="{Binding [Can Add Products]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Remove Products" Binding="{Binding [Can Remove Products]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Update Products" Binding="{Binding [Can Update Products]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Add Menus" Binding="{Binding [Can Add Menus]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Remove Menus" Binding="{Binding [Can Remove Menus]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Update Menus" Binding="{Binding [Can Update Menus]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Add Menu Contents" Binding="{Binding [Can Add Menu Contents]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Remove Menu Contents" Binding="{Binding [Can Remove Menu Contents]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Add Members" Binding="{Binding [Can Add Members]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Remove Members" Binding="{Binding [Can Remove Members]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Update Members" Binding="{Binding [Can Update Members]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can View Transactions" Binding="{Binding [Can View Transactions]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Modify Rates" Binding="{Binding [Can Modify Rates]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Modify Discounts" Binding="{Binding [Can Modify Discounts]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Modify Level-Up" Binding="{Binding [Can Modify Level-Up]}" CanUserSort="False"/>
                    <DataGridTextColumn Header="Can Modify Order Number" Binding="{Binding [Can Modify Order Number]}" CanUserSort="False"/>
                </DataGrid.Columns>
            </DataGrid>
            <ScrollViewer Height="135" Width="388" Canvas.Top="215" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="26">
                <Canvas Width="700">
                    <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Products" VerticalAlignment="Center" Canvas.Left="5" Canvas.Top="5"/>
                    <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Menus" VerticalAlignment="Center" Canvas.Left="100" Canvas.Top="5"/>
                    <TextBlock FontSize="16" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Menu items" VerticalAlignment="Center" Canvas.Left="297" Canvas.Top="5"/>
                    <TextBlock FontSize="16" TextWrapping="Wrap" Text="Members" Canvas.Left="197" Canvas.Top="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock FontSize="16" TextWrapping="Wrap" Text="Member values" Canvas.Left="411" Canvas.Top="5" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock Canvas.Left="559" TextWrapping="Wrap" Text="Others" Canvas.Top="5" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox x:Name="CanModifyRates" Content="Conversion rate" FontSize="13" Canvas.Left="411" Canvas.Top="34" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <CheckBox x:Name="CanModifyDiscount" Content="Discount percent" FontSize="13" Canvas.Left="411" Canvas.Top="86" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <CheckBox x:Name="CanModifyLevelUp" Content="Tier level-up" FontSize="13" Canvas.Left="411" Canvas.Top="60" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <CheckBox x:Name="CanViewHistory" Content="Transaction history" FontSize="13" Canvas.Left="559" Canvas.Top="34" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox x:Name="CanModifyOrderNumber" Content="Order number" FontSize="13" Canvas.Left="559" Canvas.Top="60" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox FontSize="13" x:Name="CanAddMembers" Content="Add" Canvas.Left="197" Canvas.Top="34" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox FontSize="13" x:Name="CanRemoveMembers" Content="Remove" Canvas.Left="197" Canvas.Top="60" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox FontSize="13" x:Name="CanUpdateMembers" Content="Update" Canvas.Left="197" Canvas.Top="86" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <CheckBox FontSize="13" x:Name="CanAddProducts" Content="Add" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="5" Canvas.Top="34"/>
                    <CheckBox FontSize="13" x:Name="CanRemoveProducts" Content="Remove" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="5" Canvas.Top="60"/>
                    <CheckBox FontSize="13" x:Name="CanUpdateProducts" Content="Update" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="5" Canvas.Top="86"/>
                    <CheckBox FontSize="13" x:Name="CanAddMenus" Content="Add" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="100" Canvas.Top="34"/>
                    <CheckBox FontSize="13" x:Name="CanRemoveMenus" Content="Remove" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="100" Canvas.Top="60"/>
                    <CheckBox FontSize="13" x:Name="CanUpdateMenus" Content="Update" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="100" Canvas.Top="86"/>
                    <CheckBox FontSize="13" x:Name="CanAddProductsInMenus" Content="Add" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="297" Canvas.Top="34"/>
                    <CheckBox FontSize="13" x:Name="CanRemoveProductsInMenus" Content="Remove" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="297" Canvas.Top="60"/>
                </Canvas>
            </ScrollViewer>
        </Canvas>
        <Canvas x:Name="CreateSuperadmin" Margin="411,150,393,202" Visibility="Collapsed">
            <TextBox FontSize="16" x:Name="NewSuperadminUsername" Canvas.Left="226" TextWrapping="NoWrap" Canvas.Top="55" Width="148" Style="{StaticResource RoundTextBoxStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <TextBox FontSize="16" x:Name="ShownNewSuperadminPassword" Visibility="Collapsed" Canvas.Left="226" TextWrapping="NoWrap" Canvas.Top="92" Width="148" Style="{StaticResource RoundTextBoxStyle}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <PasswordBox FontSize="16" x:Name="HiddenNewSuperadminPassword" Canvas.Left="226" Canvas.Top="92" Width="148" Style="{StaticResource RoundPassBoxStyle}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <CheckBox FontSize="13" x:Name="ShowNewSuperadminPassword" Content="Show password" Canvas.Left="244" Canvas.Top="128" HorizontalAlignment="Left" VerticalAlignment="Center" Click="ShowNewSuperadminPassword_Click"/>
            <Button FontSize="16" x:Name="CreateSuperadminAccountButton" Background="Transparent" Height="28" Content="Create account" Canvas.Left="61" Canvas.Top="157" Style="{StaticResource RoundButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Width="123" Click="CreateSuperadminAccountButton_Click"/>
            <Button FontSize="16" x:Name="ClearNewSuperadminTextboxes" Background="Transparent" Height="28" Content="Clear textboxes" Canvas.Left="226" Canvas.Top="157" Style="{StaticResource RoundButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="123" Click="ClearNewSuperadminTextboxes_Click"/>
            <TextBlock FontSize="16" Canvas.Left="39" TextWrapping="Wrap" Text="Enter the credentials for the new superadmin" Canvas.Top="17" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock FontSize="16" Canvas.Left="19" TextWrapping="Wrap" Text="New superadmin username" Canvas.Top="56" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock FontSize="16" Canvas.Left="19" TextWrapping="Wrap" Text="New superadmin password" Canvas.Top="93" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Canvas>
        <Canvas x:Name="LoginSuperadmin" Margin="420,134,416,197" Visibility="Visible">
            <TextBox FontSize="16" x:Name="CurrentSuperadminUsername" Canvas.Left="199" TextWrapping="NoWrap" Canvas.Top="62" Width="141" Style="{StaticResource RoundTextBoxStyle}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBox FontSize="16" x:Name="ShownCurrentSuperadminPassword" Visibility="Collapsed" Canvas.Left="199" TextWrapping="NoWrap" Canvas.Top="99" Width="141" Style="{StaticResource RoundTextBoxStyle}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <PasswordBox FontSize="16" x:Name="HiddenCurrentSuperadminPassword" Canvas.Left="199" Canvas.Top="99" Width="141" Style="{StaticResource RoundPassBoxStyle}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <CheckBox FontSize="13" x:Name="ShowCurrentSuperadminPassword" Content="Show password" Canvas.Left="204" Canvas.Top="134" HorizontalAlignment="Left" VerticalAlignment="Top" Click="ShowCurrentSuperadminPassword_Click">
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                </CheckBox.LayoutTransform>
            </CheckBox>
            <Button FontSize="16" x:Name="LoginSuperadminAccountButton" Background="Transparent" Height="28" Content="Login account" Canvas.Left="42" Canvas.Top="167" Style="{StaticResource RoundButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="123" Click="LoginSuperadminAccountButton_Click"/>
            <Button FontSize="16" x:Name="ClearCurrentSuperadminTextboxes" Background="Transparent" Height="28" Content="Clear textboxes" Canvas.Left="199" Canvas.Top="167" Style="{StaticResource RoundButtonStyle}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="132" Click="ClearCurrentSuperadminTextboxes_Click"/>
            <TextBlock FontSize="16" Canvas.Left="81" TextWrapping="Wrap" Text="Enter superadmin credentials" Canvas.Top="21" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock FontSize="16" Canvas.Left="27" TextWrapping="Wrap" Text="Superadmin username" Canvas.Top="63" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock FontSize="16" Canvas.Left="28" TextWrapping="Wrap" Text="Superadmin password" Canvas.Top="100" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        </Canvas>
    </Grid>
</Window>
